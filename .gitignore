target/
*.jar
*.war
*.ear
*.class
*.log

# IDE
.idea/
*.iml
*.ipr
*.iws
.vscode/
.settings/
.project
.classpath
.factorypath
.springBeans

# ОС
.DS_Store
Thumbs.db
Desktop.ini

# Frontend (React / npm)
frontend/node_modules/
frontend/build/
frontend/dist/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*
frontend/.env.local
frontend/.env.*.local

# Секреты и локальные конфиги
*.properties.local
*.pem
*.key
*.jks
*.p12
secrets/
.env

# База данных (локальные дампы)
*.sql.backup
*.dump

# Загружаемые файлы
uploads/

# Временные файлы
tmp/
logs/
*.tmp
*.bak
*.orig
